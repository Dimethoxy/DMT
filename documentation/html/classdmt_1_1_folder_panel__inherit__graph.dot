  Node3 -> Node1 [dir="back",color="firebrick4",style="solid"];
  Node3 [label="juce::Button::Listener",height=0.2,width=0.4,color="grey75", fillcolor="white", style="filled",tooltip=" "];
  Node4 -> Node1 [dir="back",color="firebrick4",style="solid"];
