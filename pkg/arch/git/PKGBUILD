# Maintainer: David Hess (Lunix) <your.email@example.com>
# PKGBUILD for Neutrino Unstable (latest git commit)

pkgname=dimethoxy-neutrino-git
# pkgver is generated from the latest git commit; the initial dummy version is 0.0.0.
pkgver=7a25a9d
pkgrel=1
pkgdesc="Unstable build of the latest commit of Neutrino from Dimethoxy's GitHub repository"
arch=('x86_64')
url="https://github.com/Dimethoxy/Neutrino"
license=('GPL3')
provides=('dimethoxy-neutrino')
conflicts=('dimethoxy-neutrino' 'dimethoxy-neutrino-git' 'dimethoxy-neutrino-bin')
# Source from the git repo (unstable build using the latest commit)
source=("git+https://github.com/Dimethoxy/Neutrino.git")
sha256sums=('SKIP')

# Build and runtime dependencies – adjust as necessary for your project.
makedepends=('gcc' 'git' 'cmake' 'ninja' 'pkg-config' 'alsa-lib' 'jack' 'ladspa' 
     'curl' 'freetype2' 'fontconfig' 'libx11' 'libxcomposite' 'libxcursor' 
     'libxext' 'libxinerama' 'libxrandr' 'libxrender' 'webkit2gtk-4.1' 'glu' 'mesa')
depends=('curl')

# Generate a proper pkgver from the git commit (using git describe)
pkgver() {
  cd "$srcdir/Neutrino"
  # Extract the latest tag (assumed to be the base version)
  base_version=$(git describe --tags --abbrev=0 | sed 's/^v//')
  # Get the short commit hash
  commit_hash=$(git rev-parse --short HEAD)
  # Construct the version string
  echo "${commit_hash}"
}


build() {
  cd "$srcdir/Neutrino"
  mkdir -p build
  cd build
  # Configure using the CMake preset defined in your project.
  cmake --preset "Linux Release" -DDMT_DISABLE_UPDATE_NOTIFICATION=ON ..
  # Build using the Release configuration.
  cmake --build . --config "Release"
}

package() {
  # Create installation directories for the plugin formats.
  install -d "$pkgdir/usr/lib/vst3/Neutrino"
  install -d "$pkgdir/usr/lib/lv2/Neutrino"
  install -d "$pkgdir/usr/lib/clap/Neutrino"
  install -d "$pkgdir/usr/share/licenses/$pkgname"

  # Install the built artifacts paths mirror those produced by your CI/CD script.
  cp -r "$srcdir/Neutrino/build/src/NeutrinoPlugin_artefacts/Release/VST3" "$pkgdir/usr/lib/vst3/Neutrino/"
  cp -r "$srcdir/Neutrino/build/src/NeutrinoPlugin_artefacts/Release/LV2" "$pkgdir/usr/lib/lv2/Neutrino/"
  cp -r "$srcdir/Neutrino/build/src/NeutrinoPlugin_artefacts/Release/CLAP" "$pkgdir/usr/lib/clap/Neutrino/"

  # Install the license.
  if [ -f "$srcdir/Neutrino/LICENSE" ]; then
    install -Dm644 "$srcdir/Neutrino/LICENSE" "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
  else
    curl -L "https://raw.githubusercontent.com/USERNAME/Neutrino/refs/heads/main/LICENSE" \
         -o "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
  fi
}
