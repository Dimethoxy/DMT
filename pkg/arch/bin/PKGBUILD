# Maintainer: Lunix (David Hess) <davidhess336@gmx.de>
pkgname='dimethoxy-neutrino-bin'
pkgver=1.1.1 # Neutrino-Version
pkgrel=1
pkgdesc="Transient Smearing Audio Effect for VST3, LV2 and CLAP compatible hosts"
arch=('x86_64')
url="https://github.com/Dimethoxy/Neutrino"
license=('GPL3')
provides=('dimethoxy-neutrino')
source=("https://github.com/Dimethoxy/Neutrino/releases/download/v$pkgver/neutrino-v$pkgver-linux.tar.gz")
sha256sums=('f61cfd287b0d58b9eca419c6c785e66a8bf94caf26b33615aa465c25bd8ee4e1')

package() {
    # Define new directories
    install -d "$pkgdir/usr/lib/vst3/Dimethoxy/Neutrino" "$pkgdir/usr/lib/lv2/Dimethoxy/Neutrino"
    install -d "$pkgdir/usr/share/licenses/$pkgname"

    # Install plugins (use cp -r for directories)
    cp -r "$srcdir/Neutrino.vst3" "$pkgdir/usr/lib/vst3/Dimethoxy/Neutrino/"
    cp -r "$srcdir/Neutrino.clap" "$pkgdir/usr/lib/clap/Dimethoxy/Neutrino/"
    cp -r "$srcdir/Neutrino.lv2" "$pkgdir/usr/lib/lv2/Dimethoxy/Neutrino/"

    # Download and install the LICENSE from the remote URL
    curl -L "https://raw.githubusercontent.com/Dimethoxy/Neutrino/refs/heads/main/LICENSE" -o "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
}